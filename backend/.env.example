# ──────────────────────────────────────────────────────────────
# JARVIS V3 — Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# === Core ===
APP_NAME=JARVIS V3
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=production

# === Server ===
HOST=0.0.0.0
PORT=8001
WORKERS=4
MAX_CONNECTIONS=1000

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5432/jarvis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# === JWT ===
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === LLM Providers ===
# Primary: Groq
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Fallback: OpenAI
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

# Fallback: OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct

# Fallback: Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Local LLM (optional)
LOCAL_LLM_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=deepseek-coder-6.7b-instruct

# === Speech-to-Text ===
WHISPER_MODEL_SIZE=tiny
WHISPER_MODEL_DIR=data/faster_whisper_models
STT_FALLBACK_CHAIN=faster-whisper,lite,vosk

# === Text-to-Speech ===
TTS_ENGINE=espeak
TTS_VOICE=en-us
TTS_SPEED=160

# === Rate Limiting ===
RATE_LIMIT_PER_IP=60
RATE_LIMIT_PER_USER=120
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=10

# === WebSocket ===
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL=30
WS_MAX_IDLE_TIME=300

# === Security ===
CORS_ORIGINS=http://localhost:3000,https://jarvis.app,capacitor://localhost
SHUTDOWN_TOKEN=
ENFORCE_HTTPS=true
MAX_UPLOAD_SIZE=10485760

# === MCP ===
MCP_GITHUB_TOKEN=
MCP_BROWSER_HEADLESS=true
MCP_FILESYSTEM_ROOT=/data/mcp

# === Monitoring ===
OTEL_SERVICE_NAME=jarvis-v3
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# === Android ===
ANDROID_FCM_SERVER_KEY=
ANDROID_PACKAGE_NAME=com.jarvis.assistant

# === Feature Flags ===
ENABLE_VOICE=true
ENABLE_MCP=true
ENABLE_GOALS=true
ENABLE_TOOLS=true
ENABLE_AUTO_SKILLS=true
ENABLE_TELEMETRY=false
